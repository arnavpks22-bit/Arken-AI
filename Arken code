#include <DHT.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// ---------- OLED Setup ----------
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 oled(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// ---------- Pin Definitions ----------
#define DHTPIN 27
#define DHTTYPE DHT11
#define MQ2_PIN 26
#define RAIN_SENSOR_PIN 33
#define FLAME_PIN 34
#define BUZZER_PIN 25

#define TEMP_HUMID_ALERT_LED 23

#define LED_FIRE 15
#define LED_GAS 2
#define LED_FLOOD 4
#define LED_SAFE 5

// ---------- Global Variables ----------
DHT dht(DHTPIN, DHTTYPE);
float temperature = 0.0;
float humidity = 0.0;
int gasLevel = 0;
bool fireAlert = false;
bool rainAlert = false;
bool tempHumidAlert = false;

// Timing variables
unsigned long lastOLEDUpdate = 0;
unsigned long lastBuzzerUpdate = 0;
int buzzerStep = 0;

void setup() {
  Serial.begin(9600);
  delay(1500);
  dht.begin();

  pinMode(RAIN_SENSOR_PIN, INPUT);
  pinMode(FLAME_PIN, INPUT);
  pinMode(MQ2_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(TEMP_HUMID_ALERT_LED, OUTPUT);

  pinMode(LED_FIRE, OUTPUT);
  pinMode(LED_GAS, OUTPUT);
  pinMode(LED_FLOOD, OUTPUT);
  pinMode(LED_SAFE, OUTPUT);

  Wire.begin(21, 22);  // SDA, SCL for OLED
  if (!oled.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED init failed");
    while (true);
  }
  oled.clearDisplay();
  oled.display();
}

void loop() {
  // Sensor Readings
  float newTemp = dht.readTemperature();
  float newHumid = dht.readHumidity();

  if (!isnan(newTemp)) temperature = newTemp;
  if (!isnan(newHumid)) humidity = newHumid;

  gasLevel = analogRead(MQ2_PIN);
  fireAlert = (digitalRead(FLAME_PIN) == LOW);
  rainAlert = (digitalRead(RAIN_SENSOR_PIN) == LOW); // LOW = Rain detected
  tempHumidAlert = (temperature >= 39.0);

  // Debugging
  Serial.print("Temp: "); Serial.print(temperature);
  Serial.print(" °C  Humidity: "); Serial.print(humidity);
  Serial.print("%  Gas: "); Serial.print(gasLevel);
  Serial.print("  Fire: "); Serial.print(fireAlert);
  Serial.print("  Flood: "); Serial.println(rainAlert);

  // Update OLED every 1 second
  if (millis() - lastOLEDUpdate >= 1000) {
    updateOLED();
    lastOLEDUpdate = millis();
  }

  updateBuzzerNonBlocking();
  updateLEDs();

  // Temp + Humid alert LED blink
  if (tempHumidAlert) {
    digitalWrite(TEMP_HUMID_ALERT_LED, millis() / 300 % 2);
  } else {
    digitalWrite(TEMP_HUMID_ALERT_LED, LOW);
  }
}

// ---------- OLED ----------
void updateOLED() {
  oled.clearDisplay();
  oled.setTextColor(WHITE);

  if (gasLevel > 3000) {
    oled.setTextSize(2);
    oled.setCursor(0, 0);
    oled.println("WARNING");
    oled.setTextSize(1);
    oled.setCursor(0, 30);
    oled.println("Gas Leak Detected");
    oled.setCursor(0, 50);
    oled.println("Evacuate Now!");
  }
  else if (fireAlert) {
    oled.setTextSize(2);
    oled.setCursor(0, 0);
    oled.println("WARNING");
    oled.setTextSize(1);
    oled.setCursor(0, 30);
    oled.println("Fire Alert");
    oled.setCursor(0, 50);
    oled.println("Evacuate Now!");
  }
  else if (rainAlert) {
    oled.setTextSize(2);
    oled.setCursor(0, 0);
    oled.println("WARNING");
    oled.setTextSize(1);
    oled.setCursor(0, 30);
    oled.println("Flood Alert");
    oled.setCursor(0, 50);
    oled.println("Evacuate Now");
  }
  else if (tempHumidAlert) {
    oled.setTextSize(2);
    oled.setCursor(0, 0);
    oled.println("CAUTION");
    oled.setTextSize(1);
    oled.setCursor(0, 30);
    oled.println("Heat & Humid Risk");
    oled.setCursor(0, 50);
    oled.println("Stay Hydrated!");
  }
  else {
    oled.setTextSize(1);
    oled.setCursor(0, 0);
    oled.println("Status: ALL SAFE");
    oled.println("--------------------");
    oled.print("Temp: "); oled.print(temperature); oled.println(" C");
    oled.print("Humi: "); oled.print(humidity); oled.println(" %");
    oled.print("Gas:  "); oled.println(gasLevel);
    oled.print("Fire: "); oled.println(fireAlert ? "YES" : "NO");
    oled.print("Flood: "); oled.println(rainAlert ? "YES" : "NO");
    oled.print("Heat+Humid: "); oled.println(tempHumidAlert ? "YES" : "NO");
  }

  oled.display();
}

// ---------- Non-blocking Buzzer ----------
void updateBuzzerNonBlocking() {
  if (gasLevel > 3000) {
    gasSirenNonBlocking();
  }
  else if (fireAlert) {
    fireToneNonBlocking();
  }
  else if (rainAlert) {
    rainToneNonBlocking();
  }
  else if (tempHumidAlert) {
    tempToneNonBlocking();
  }
  else {
    noTone(BUZZER_PIN);
    buzzerStep = 0;
  }
}

void gasSirenNonBlocking() {
  if (millis() - lastBuzzerUpdate >= 2) {
    static int freq = 1000;
    static bool up = true;
    tone(BUZZER_PIN, freq);
    if (up) freq += 20; else freq -= 20;
    if (freq >= 1500) up = false;
    if (freq <= 1000) up = true;
    lastBuzzerUpdate = millis();
  }
}

void fireToneNonBlocking() {
  if (millis() - lastBuzzerUpdate >= 300) {
    buzzerStep = !buzzerStep;
    tone(BUZZER_PIN, buzzerStep ? 800 : 1200);
    lastBuzzerUpdate = millis();
  }
}

void tempToneNonBlocking() {
  if (millis() - lastBuzzerUpdate >= 300) {
    buzzerStep = !buzzerStep;
    tone(BUZZER_PIN, buzzerStep ? 700 : 1500);
    lastBuzzerUpdate = millis();
  }
}

void rainToneNonBlocking() {
  if (millis() - lastBuzzerUpdate >= 400) {
    buzzerStep = !buzzerStep;
    if (buzzerStep) tone(BUZZER_PIN, 900); else noTone(BUZZER_PIN);
    lastBuzzerUpdate = millis();
  }
}

// ---------- LEDs ----------
void updateLEDs() {
  digitalWrite(LED_FIRE, fireAlert ? HIGH : LOW);
  digitalWrite(LED_GAS, gasLevel > 3000 ? HIGH : LOW);
  digitalWrite(LED_FLOOD, rainAlert ? HIGH : LOW);
  digitalWrite(LED_SAFE, (!fireAlert && gasLevel < 3000 && !rainAlert && !tempHumidAlert) ? HIGH : LOW);
}



